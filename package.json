{
  "name": "devtoys-web",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=26.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "biome format --write .",
    "format:check": "biome format .",
