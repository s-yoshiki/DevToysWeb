{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@devtoys/web", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "web-mock",
      "runtimeExecutable": "pnpm",
